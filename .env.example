APP_NAME=tb_living
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# --- Producción TBN Living (Synkai API) ---
# API pública: https://api.tbnliving.com  |  App miembros: https://front.tbnliving.com
APP_URL=https://api.tbnliving.com
FRONTEND_URL=https://front.tbnliving.com
# Orígenes del navegador permitidos (coma, sin espacios problemáticos). Incluye www si lo usas.
# Lista explícita (opcional: config/cors.php ya incluye admin/front y patrones *.tbnliving.com)
CORS_ALLOWED_ORIGINS=https://admin.tbnliving.com,https://front.tbnliving.com,https://tbnliving.com
# Obligatorio para Sanctum SPA (admin/front en otro subdominio que api)
CORS_SUPPORTS_CREDENTIALS=true
CORS_MAX_AGE=86400
# Dominios host (sin https://) que reciben middleware stateful + sesión
SANCTUM_STATEFUL_DOMAINS=admin.tbnliving.com,front.tbnliving.com,api.tbnliving.com,tbnliving.com,localhost,localhost:5173,127.0.0.1
# Minutos hasta expirar tokens Bearer (vacío = sin expiración automática)
SANCTUM_TOKEN_EXPIRATION=
SANCTUM_REVOKE_OTHER_TOKENS_ON_LOGIN=false
SANCTUM_TOKEN_PREFIX=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tbnliving_synkai
DB_USERNAME=tbnliving_user
DB_PASSWORD=

# SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
# Producción multi-subdominio: .tbnliving.com (cookie compartida entre front/admin/api)
SESSION_DOMAIN=.tbnliving.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=none

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# --- Redis (producción: cache + colas + sesiones) ---
# Desarrollo local sin Redis: database / file / sync
QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=redis

CACHE_PREFIX=tbn_api_cache_

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_PREFIX=tbn_api_
REDIS_QUEUE_CONNECTION=queue
REDIS_CACHE_CONNECTION=cache
SESSION_CONNECTION=session
REDIS_QUEUE_RETRY_AFTER=120

MLM_REDIS_ENABLED=true
MLM_CACHE_TTL_ADMIN_DASHBOARD=120
MLM_CACHE_TTL_WALLET_BALANCE=30
MLM_LOCK_WALLET_SECONDS=15
MLM_LOCK_WITHDRAWAL_SECONDS=30
MLM_LOCK_ORDER_PAYMENT_SECONDS=20
MLM_REDIS_QUEUE_LIST=high,default,mail,binary,residual,withdrawals,low
MLM_HORIZON_ENABLED=false

MEMCACHED_HOST=127.0.0.1

# Gmail (App Password): https://myaccount.google.com/apppasswords
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tu-correo@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# MAIL_ENCRYPTION=tls
# MAIL_FROM_ADDRESS=tu-correo@gmail.com
# MAIL_FROM_NAME="${APP_NAME}"
MAIL_MAILER=smtp
MAIL_HOST=smtp.tuproveedor.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=no-reply@tbnliving.com
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"



########################################
# MLM CONFIG - SYNKAI
########################################

# Roles admin
MLM_ADMIN_ROLES=admin,superadmin,support

# Moneda
MLM_CURRENCY=BOB

# Permitir bajar de rango
MLM_RANK_ALLOW_DOWNGRADE=true

# Código de socio
MLM_MEMBER_CODE_MIN=10
MLM_MEMBER_CODE_MAX=1000000

# Activación mensual
MLM_MONTHLY_ACTIVATION_PV=50

# Ciclo de calificación
MLM_CYCLE_START_DAY=1
MLM_CYCLE_END_DAY=27

# Valor del PV
MLM_BOB_PER_PV=7

########################################
# BIR (BONO INICIO RÁPIDO)
########################################

MLM_BIR_BASE=pv

########################################
# BINARIO
########################################

MLM_BINARY_LEGACY_FLAT=false
MLM_BINARY_PAYOUT_PER_PV=1
MLM_BINARY_BOB_PER_PV=7
MLM_BINARY_MATCHED_RATE=0.21
MLM_BINARY_CACHE_TTL=600

# Tope binario
MLM_BINARY_CAP_ENABLED=false
MLM_BINARY_CAP_MODE=weekly
MLM_BINARY_CAP_MAX_BOB=50000

########################################
# COLAS (QUEUES)
########################################

MLM_QUEUE_BINARY=default
MLM_QUEUE_RESIDUAL=default
MLM_QUEUE_WITHDRAWALS=default

########################################
# FACTURACIÓN
########################################

MLM_INVOICE_TAX_PCT=0
MLM_INVOICE_ISSUER_NIT=
MLM_INVOICE_ISSUER_NAME=
MLM_INVOICE_AUTH_CODE=
# Facturación electrónica (API impuestos)
MLM_INVOICE_ELECTRONIC_ENABLED=false
MLM_INVOICE_ELECTRONIC_URL=
MLM_INVOICE_ELECTRONIC_TOKEN=
MLM_INVOICE_ELECTRONIC_TIMEOUT=30
#########################################
MLM_RANK_PLATA_PV=3600
MLM_ONBOARDING_PLATA_PV=1200
MLM_ONBOARDING_PLATA_MONTHS=3
MLM_AUTO_OKM_TARGET_USD=90000
MLM_BOB_PER_USD=7
MLM_BINARY_LEFT_PV=0
#########################################
MLM_BOB_PER_USD=7
MLM_BINARY_HYBRID_WEEKLY_CAP_USD=2500
MLM_BINARY_HYBRID_DAILY=true
MLM_BINARY_HYBRID_RATE=0.21
####################################
APP_TIMEZONE=America/La_Paz
########################################

# Panel admin / sync interno (server-to-server)
INTERNAL_SYNC_TOKEN=
INTERNAL_SYNC_IP_ALLOWLIST=
INTERNAL_SYNC_RATE_LIMIT_PER_MINUTE=120
INTERNAL_PANEL_SYSTEM_USER_ID=
ADMIN_PANEL_DEFAULT_COUNTRY=BO